@model IEnumerable<RECIPE.Models.Recipe>

@{
    ViewData["Title"] = "User Recipe Details";
}

<h2 class="text-center mb-4">@ViewBag.UserName’s Recipes</h2>

@if (Model != null && Model.Any())
{
    foreach (var recipe in Model)
    {
        <div class="card mb-4 shadow-sm p-3 rounded-4 text-center">
            <div class="card-body">
                <h4 class="card-title text-primary">@recipe.Title</h4>
              

                <div class="mb-3">
                    <img src="@recipe.Image" alt="@recipe.Title" class="img-fluid rounded mb-3" style="max-height: 250px; object-fit: cover;">
                </div>

                <h5>Ingredients:</h5>
                <p class="text-muted">@recipe.Ingredients</p>
                <p><strong>Cooking Time:</strong> @recipe.CookingTime</p>
                <p><strong>Difficulty:</strong> @recipe.DifficultyLevel</p>
                <h5>Preparation Steps:</h5>
                <p class="text-muted">@recipe.Steps</p>

                <p><strong>Likes:</strong> @recipe.LikeCount ❤️</p>

                <hr />
                
            </div>
        </div>
    }
}
else
{
    <div class="text-center text-muted">
        <p>No recipes found for this user.</p>
    </div>
}
