@model RECIPE.Models.Recipe

@{
    ViewData["Title"] = "Recipe Details";
}

<div class="container mt-4">
    <h2 class="text-center text-success">@Model.Title</h2>
    <hr />

    <div class="row mt-4">
        <div class="col-md-5">
            <img src="@Model.Image" alt="@Model.Title" class="img-fluid rounded shadow" />
        </div>

        <div class="col-md-7">
            <h4><strong>Author ID:</strong> @Model.Author</h4>
            <h4><strong>Cooking Time:</strong> @Model.CookingTime</h4>
            <h4><strong>Difficulty Level:</strong> @Model.DifficultyLevel</h4>
            <h4><strong>Likes:</strong> @Model.LikeCount</h4>
        </div>
    </div>

    <div class="mt-4">
        <h3>Ingredients</h3>
        <p>@Model.Ingredients</p>
    </div>

    <div class="mt-4">
        <h3>Steps</h3>
        <p>@Model.Steps</p>
    </div>

    <div class="mt-4 text-center">
        <a asp-action="ViewRecipe" class="btn btn-secondary">Back to Recipe List</a>
    </div>
</div>
